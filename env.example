# =============================================================================
# PlanSmart Personal Assistant — environment template.
# Copy this file to `.env` (with the leading dot) and populate the placeholder
# values. The runtime loads `.env` exactly once via pydantic-settings; missing
# required keys cause an explicit ValidationError at startup, not a silent
# failure.
#
# NOTE: This template is committed as `env.example` (no leading dot) because
# harness permission settings protect files matching `.env*` from
# auto-generation. Rename to `.env` locally after populating.
# =============================================================================

# --- Anthropic (chat + tool-use) ------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (embeddings for the RAG store) --------------------------------
OPENAI_API_KEY=sk-...
# Optional; falls back to `text-embedding-3-small` if unset.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Pinecone (vector storage) --------------------------------------------
PINECONE_API_KEY=pcsk-...
# Optional; falls back to `plansmart` if unset.
# PINECONE_INDEX_NAME=plansmart

# --- Tavily (web search over the stdio MCP server) ------------------------
# Required. Injected into the environment of the `tavily_server.py`
# subprocess spawned by TavilyMCPClient so the `tavily_search` tool can
# reach the Tavily API.
TAVILY_API_KEY=tvly-...

# --- Optional runtime knobs -----------------------------------------------
# ANTHROPIC_MODEL=claude-opus-4-7
# ANTHROPIC_MAX_TOKENS=2048
# MAX_HISTORY_TURNS=20
# MAX_TOOL_ITERATIONS=5
# LOG_LEVEL=INFO
# KNOWLEDGE_DIR=knowledge
